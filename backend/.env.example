# ─────────────────────────────────────────────────────────────────────────────
# ResumePilot 2.0 — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Production: Neon serverless Postgres (use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@host/resumepilot?sslmode=require
# Local dev fallback (SQLite — no Postgres needed):
# DATABASE_URL=sqlite+aiosqlite:///./resumepilot.db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-plus-char-string-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520   # 8 days

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Cloudinary (resume file storage) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── AI (mocked in MVP — set AI_MOCK_MODE=false to enable Gemini) ─────────────
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com
AI_MOCK_MODE=true

# ── Email — Resend (swap to SENDGRID_API_KEY later) ──────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=ResumePilot <noreply@resumepilot.app>

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","https://app.resumepilot.com"]
DEBUG=false
